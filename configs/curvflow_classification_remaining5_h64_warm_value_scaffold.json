{
  "datasets": ["CLINTOX", "TOX21", "HIV", "SIDER", "TOXCAST"],
  "seeds": [0, 1, 2],
  "epochs": 120,
  "batch_size": 64,
  "hidden_channels": 64,
  "num_layers": 2,
  "num_timesteps": 2,
  "dropout": 0.1,
  "lr": 0.0005,
  "weight_decay": 0.00001,
  "patience": 20,
  "d_max": 4,
  "support_hops": 3,
  "beta": 0.2,
  "tau": 0.5,
  "residual_gate_init": 0.05,
  "residual_placement": "post",
  "num_residual_steps": 1,
  "residual_message": "value",
  "residual_norm_mode": "layernorm",
  "split_strategy": "scaffold",
  "warm_start_coremol": true,
  "tcm_graphs": 24,
  "tcm_k": 10
}
