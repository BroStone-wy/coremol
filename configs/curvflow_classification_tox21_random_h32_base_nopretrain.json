{
  "datasets": ["TOX21"],
  "seeds": [0, 1, 2],
  "epochs": 120,
  "batch_size": 64,
  "hidden_channels": 32,
  "num_layers": 2,
  "num_timesteps": 2,
  "dropout": 0.1,
  "lr": 0.001,
  "weight_decay": 0.00001,
  "patience": 20,
  "d_max": 4,
  "support_hops": 3,
  "beta": 0.2,
  "tau": 0.5,
  "residual_gate_init": 0.1,
  "residual_placement": "post",
  "num_residual_steps": 1,
  "residual_message": "value",
  "residual_norm_mode": "layernorm",
  "split_strategy": "curvflow_random",
  "random_train_fraction": 0.7,
  "random_valid_fraction": 0.2,
  "variants": ["base"],
  "tcm_graphs": 2,
  "tcm_k": 10
}
